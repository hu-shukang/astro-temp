---
import "../styles/global.css";
import Layout from "./Layout.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Layout title={title}>
  <div
    class="bg-background flex min-h-screen flex-col items-center justify-center px-4 py-12"
  >
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <a href="/" class="font-heading text-primary text-2xl font-bold">
          でんきポータル
        </a>
      </div>
      <div class="bg-surface border-border rounded-xl border p-8 shadow-sm">
        <slot />
      </div>
    </div>
  </div>
</Layout>
